# %% [markdown]
# # GIS Layer Visualization

import requests
import geopandas as gpd
import matplotlib.pyplot as plt

# Step 1: Fetch the data from the URL
url = "https://openlandmap.org/?center=2.1004671584784513,41.30922007638128&zoom=13.696860721260677&opacity=51&base=OpenStreetMap&layer=lc_glc.fcs30d&time=2022"
response = requests.get(url)

# Step 2: Parse the data into a GeoDataFrame
gdf = gpd.read_file(response.content, driver='GeoJSON')

# Step 3: Visualize the data
plt.figure(figsize=(10, 6))
gdf.plot(color='blue', edgecolor='black')
plt.title('GIS Layer Visualization')
plt.xlabel('Longitude')
plt.ylabel('Latitude')
plt.show()
